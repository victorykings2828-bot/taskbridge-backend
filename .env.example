# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/taskbridge

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
COOKIE_SECRET=change_me_cookie_secret_min_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (optional — leave blank to disable Google login) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Email ──────────────────────────────────────────────────────────────────
# PREFERRED on Render (free tier blocks outbound SMTP): Brevo HTTP API over HTTPS.
#   1. Sign up at brevo.com (free, 300 emails/day)
#   2. Verify a sender email under "Senders, Domains & Dedicated IPs"
#   3. Create an API key under "SMTP & API" → "API Keys"
BREVO_API_KEY=
# The verified sender address shown as the "From". Falls back to EMAIL_USER.
EMAIL_FROM_ADDR=

# SMTP fallback (only works where outbound SMTP is allowed, e.g. paid Render).
# For Gmail use an App Password (Google Account → Security → App Passwords).
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ── Cloudinary (optional — leave blank for mock/local mode) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay ──────────────────────────────────────────────────────────────────
# HOW TO GET TEST KEYS:
#   1. Sign up / log in at https://dashboard.razorpay.com
#   2. Toggle to TEST MODE (switch in the top-left corner)
#   3. Go to Settings → API Keys → Generate Key
#   4. Copy Key ID (starts with rzp_test_) and Key Secret
#
# HOW TO SET UP WEBHOOK (for subscription.charged / cancelled events):
#   1. In Razorpay Dashboard → Webhooks → Add New Webhook
#   2. Webhook URL: https://<your-backend-domain>/api/payments/webhook
#   3. Events to subscribe:
#        payment.captured
#        subscription.charged
#        subscription.cancelled
#        subscription.halted
#   4. Copy the webhook secret shown — paste it below.
#   NOTE: RAZORPAY_WEBHOOK_SECRET is required. If it is unset, all webhook
#         requests are rejected (no signature = no trust).
#
# For local testing use Razorpay's test card: 4111 1111 1111 1111 / any future expiry / CVV 123
# UPI test ID: success@razorpay
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Platform analytics (internal use) ─────────────────────────────────────────
# Used to protect the /analytics/platform endpoint
PLATFORM_ANALYTICS_KEY=
