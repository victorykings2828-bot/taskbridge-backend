# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/taskbridge

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
COOKIE_SECRET=change_me_cookie_secret_min_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (optional — leave blank to disable Google login) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Email ──────────────────────────────────────────────────────────────────
# PREFERRED on Render (free tier blocks outbound SMTP): Brevo HTTP API over HTTPS.
#   1. Sign up at brevo.com (free, 300 emails/day)
#   2. Verify a sender email under "Senders, Domains & Dedicated IPs"
#   3. Create an API key under "SMTP & API" → "API Keys"
BREVO_API_KEY=
# The verified sender address shown as the "From". Falls back to EMAIL_USER.
EMAIL_FROM_ADDR=

# SMTP fallback (only works where outbound SMTP is allowed, e.g. paid Render).
# For Gmail use an App Password (Google Account → Security → App Passwords).
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ── Cloudinary (optional — leave blank for mock/local mode) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (optional — leave blank to disable payment flows) ────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Platform analytics (internal use) ─────────────────────────────────────────
# Used to protect the /analytics/platform endpoint
PLATFORM_ANALYTICS_KEY=
